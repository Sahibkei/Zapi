{
  "name": "zapi",
  "version": "0.1.0",
  "private": true,
  "description": "Live-pull, zero-persistence fundamentals API.",
  "scripts": {
    "dev": "tsx watch apps/api/src/index.ts",
    "dev:test": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/apps/api/src/index.js",
    "test": "vitest run",
    "export:statement": "node scripts/export-statement.mjs",
    "smoke:test": "node scripts/smoke-test.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "fastify": "^5.6.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
